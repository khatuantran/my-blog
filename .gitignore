# Dependencies
node_modules/
.pnpm-store/

# Local storage uploads (ADR-010 STORAGE_DRIVER=local) — giữ thư mục, bỏ file
storage/uploads/*
!storage/uploads/.gitkeep

# Build output
dist/
build/
out/
.next/
.turbo/
*.tsbuildinfo
.tsbuild-node/

# Env (KHÔNG commit secret — chỉ commit .env.example)
.env
.env.*
!.env.example
!.env.*.example

# Test / coverage
coverage/
.nyc_output/
playwright-report/
test-results/

# Prisma
apps/api/prisma/*.db
apps/api/prisma/*.db-journal

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE / Editor
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

