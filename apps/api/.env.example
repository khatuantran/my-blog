# MyBlog Backend (apps/api) — env template
# Copy to .env.local (gitignored) và fill real values cho local dev.
# Reference đầy đủ: docs/DEPLOYMENT.md > Env Vars Matrix

# ──────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────
# Local Docker: postgres-main on :5432
DATABASE_URL="postgresql://myblog:myblog@localhost:5434/myblog?schema=public"
# Direct connection (cho Prisma migrate)
DIRECT_URL="postgresql://myblog:myblog@localhost:5434/myblog?schema=public"
# Test DB: postgres-test on :5433
DATABASE_URL_TEST="postgresql://myblog:myblog@localhost:5433/myblog_test?schema=public"

# ──────────────────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET="change-me-32-byte-random-base64-string"
JWT_REFRESH_SECRET="change-me-different-32-byte-random-base64-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ──────────────────────────────────────────────────────────
# Storage driver (ADR-010): 'cloudinary' (prod) | 'local' (dev volume)
# ──────────────────────────────────────────────────────────
# local: upload qua POST /files/upload → ghi vào STORAGE_LOCAL_PATH, serve tại /uploads.
# cloudinary: signed direct upload (cần CLOUDINARY_* dưới đây).
STORAGE_DRIVER="cloudinary"
# Dir lưu file khi STORAGE_DRIVER=local (bind-mount ./storage/uploads; container: /app/storage/uploads)
STORAGE_LOCAL_PATH="./storage/uploads"
# Base URL build link file local (BE origin mà browser truy cập được)
STORAGE_PUBLIC_URL="http://localhost:3001"

# ──────────────────────────────────────────────────────────
# Cloudinary (signed upload) — chỉ bắt buộc khi STORAGE_DRIVER=cloudinary
# ──────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET="myblog_uploads"

# ──────────────────────────────────────────────────────────
# Admin seed
# ──────────────────────────────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-strong-password"

# ──────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────
PORT="3001"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
# FR-18: số hop proxy tin tưởng (X-Forwarded-For → client IP thật). 1 = Fly.io single proxy.
TRUST_PROXY="1"

# ──────────────────────────────────────────────────────────
# Sentry (optional)
# ──────────────────────────────────────────────────────────
SENTRY_DSN=""
