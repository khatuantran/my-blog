# MyBlog Backend (apps/api) — env template
# Copy to .env.local (gitignored) và fill real values cho local dev.
# Reference đầy đủ: docs/DEPLOYMENT.md > Env Vars Matrix

# ──────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────
# Local Docker: postgres-main on :5432
DATABASE_URL="postgresql://myblog:myblog@localhost:5432/myblog?schema=public"
# Direct connection (cho Prisma migrate)
DIRECT_URL="postgresql://myblog:myblog@localhost:5432/myblog?schema=public"
# Test DB: postgres-test on :5433
DATABASE_URL_TEST="postgresql://myblog:myblog@localhost:5433/myblog_test?schema=public"

# ──────────────────────────────────────────────────────────
# JWT
# ──────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET="change-me-32-byte-random-base64-string"
JWT_REFRESH_SECRET="change-me-different-32-byte-random-base64-string"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ──────────────────────────────────────────────────────────
# Cloudinary (signed upload)
# ──────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_PRESET="myblog_uploads"

# ──────────────────────────────────────────────────────────
# Admin seed
# ──────────────────────────────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-strong-password"

# ──────────────────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────────────────
PORT="3001"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"

# ──────────────────────────────────────────────────────────
# Sentry (optional)
# ──────────────────────────────────────────────────────────
SENTRY_DSN=""
