{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV", "CI"],
  "globalDependencies": [".env", ".env.local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "!**/node_modules/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:unit": {
      "dependsOn": ["^build"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "openapi:gen": {
      "inputs": ["src/**/*.ts", "scripts/dump-openapi.ts"],
      "outputs": ["../../docs/contracts/openapi.yaml"]
    },
    "openapi:types": {
      "dependsOn": ["api#openapi:gen"],
      "inputs": ["../../docs/contracts/openapi.yaml"],
      "outputs": ["src/types/api.generated.ts"]
    }
  }
}
